    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^24.10.1",
    "prisma": "^6.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
