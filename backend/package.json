{
  "name": "health-tracker-backend",
  "version": "1.0.0",
  "description": "Backend API for the Health Tracker project",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
